    {
      "id": "-KDeawOY_2ttdf6fYOOyG",
      "type": "text",
      "x": 326.82700775417766,
      "y": 187.35726099311137,
      "width": 930,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
